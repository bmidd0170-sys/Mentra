# ------------------------------------------------------------
# Database (Prisma)
# ------------------------------------------------------------
DATABASE_URL="postgresql://mentra:mentra@localhost:5432/mentra?schema=public"

# ------------------------------------------------------------
# OpenAI
# Get your key from: https://platform.openai.com/account/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY="sk-your-openai-api-key"

# ------------------------------------------------------------
# Firebase Web App (Client)
# Create Firebase project -> Add Web App -> copy config values
# Also enable Auth providers (Google + Email/Password) in Firebase Console.
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"