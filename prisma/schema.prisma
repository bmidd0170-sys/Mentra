generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String               @id @default(cuid())
  createdByUserId String?
  name            String
  description     String?
  gradingSystem   String?
  gradingRubric   String?              // JSON array of grade entries: [{ grade, minScore, maxScore, description }, ...]
  createdBy       User?                @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rules           Rule[]
  assignments     Assignment[]
  members         OrganizationMember[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String?
  organizationsCreated Organization[]       @relation("OrganizationCreatedBy")
  assignmentsCreated   Assignment[]         @relation("AssignmentCreatedBy")
  submissions          Submission[]
  memberships          OrganizationMember[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Rule {
  id             String           @id @default(cuid())
  organizationId String
  title          String
  description    String
  weight         Int              @default(1)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    AssignmentRule[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Assignment {
  id              String           @id @default(cuid())
  organizationId  String
  createdByUserId String?
  title           String
  instructions    String?
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rules           AssignmentRule[]
  submissions     Submission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AssignmentRule {
  assignmentId String
  ruleId       String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  rule         Rule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([assignmentId, ruleId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String?
  content      String
  aiScore      Float?
  status       String     @default("draft")
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  feedback     Feedback?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Feedback {
  id              String     @id @default(cuid())
  submissionId    String     @unique
  overallComment  String
  strengths       String?
  improvements    String?
  rubricBreakdown Json?
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
}
