generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id              String               @id @default(cuid())
  createdByUserId String?
  name            String
  description     String?
  gradingSystem   String?
  gradingRubric   String?              // JSON array of grade entries: [{ grade, minScore, maxScore, description }, ...]
  createdBy       User?                @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  criteria        Criterion[]
  rules           Rule[]
  assignments     Assignment[]
  members         OrganizationMember[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Criterion {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  description    String?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  levels         Level[]
  results        Result[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, name])
}

model Level {
  id          String     @id @default(cuid())
  criterionId String
  label       String
  score       Float
  description String
  criterion   Criterion  @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  results     Result[]   @relation("SelectedLevelResults")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([criterionId, label])
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String?
  organizationsCreated Organization[]       @relation("OrganizationCreatedBy")
  assignmentsCreated   Assignment[]         @relation("AssignmentCreatedBy")
  submissions          Submission[]
  memberships          OrganizationMember[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Rule {
  id             String           @id @default(cuid())
  organizationId String
  title          String
  description    String
  weight         Int              @default(1)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    AssignmentRule[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Assignment {
  id              String           @id @default(cuid())
  organizationId  String
  createdByUserId String?
  title           String
  instructions    String?
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rules           AssignmentRule[]
  submissions     Submission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AssignmentRule {
  assignmentId String
  ruleId       String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  rule         Rule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([assignmentId, ruleId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String?
  content      String
  aiScore      Float?
  status       String     @default("draft")
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  feedback     Feedback?
  results      Result[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Result {
  id                     String      @id @default(cuid())
  submissionId           String
  criterionId            String
  selectedLevelId        String
  reasoning              String
  improvementSuggestions Json
  confidence             Float
  submission             Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  criterion              Criterion   @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  selectedLevel          Level       @relation("SelectedLevelResults", fields: [selectedLevelId], references: [id], onDelete: Restrict)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@unique([submissionId, criterionId])
}

model Feedback {
  id              String     @id @default(cuid())
  submissionId    String     @unique
  overallComment  String
  strengths       String?
  improvements    String?
  rubricBreakdown Json?
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
}
